{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TenantCoreDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Jwt": {
    "Secret": "your-super-secret-key-change-this-in-production-at-least-32-chars",
    "Issuer": "TenantCore.Auth",
    "Audience": "TenantCore.Api"
  },
  "AllowedHosts": "*"
}
