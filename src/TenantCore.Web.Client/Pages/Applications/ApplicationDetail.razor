
@page "/applications/{Id:guid}"
@layout AuthorizedLayout
@using MudBlazor
@using TenantCore.Web.Client.Services
@using TenantCore.Shared.Dtos.Auth
@inject IApplicationApiClient AppClient
@inject IAuthApiClient AuthClient
@inject AuthStateService AuthState
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject RoleCacheService RoleCache

<PageTitle>Application Details - TenantCore</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_notFound)
{
    <MudPaper Class="pa-6" Elevation="2">
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Warning" Style="font-size: 4rem;" />
            <MudText Typo="Typo.h5">Application Not Found</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/applications">Back to Applications</MudButton>
        </MudStack>
    </MudPaper>
}
else if (_app is not null)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Justify="Justify.SpaceBetween">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => NavigationManager.NavigateTo("/applications"))" />
            <MudAvatar Size="Size.Large" Color="@GetTypeColor(_app.ApplicationType)">@_app.ApplicationName[0]</MudAvatar>
            <MudStack Spacing="0">
                <MudText Typo="Typo.h4">@_app.ApplicationName</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@_app.ApplicationCode</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="@GetTypeColor(_app.ApplicationType)">@GetTypeName(_app.ApplicationType)</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="@(_app.IsActive ? Color.Success : Color.Error)" Variant="Variant.Filled">
                        @(_app.IsActive ? "Active" : "Inactive")
                    </MudChip>
                    @if (_app.IsOwner)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.Star">Owner</MudChip>
                    }
                </MudStack>
            </MudStack>
        </MudStack>
        @if (IsAdmin || IsClinicAdminForApp)
        {
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Edit"
                           OnClick="@(() => NavigationManager.NavigateTo($"/applications/{Id}/edit"))">
                    Edit
                </MudButton>
                @if (IsAdmin)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="@(_app.IsOwner ? Color.Default : (_isAppActive ? Color.Error : Color.Success))"
                               StartIcon="@(_isAppActive ? Icons.Material.Filled.Block : Icons.Material.Filled.CheckCircle)"
                               OnClick="@(() => _toggleAppStatusDialogVisible = true)"
                               Disabled="_togglingAppStatus || _app.IsOwner">
                        @(_isAppActive ? "Deactivate" : "Activate")
                    </MudButton>
                }
            </MudStack>
        }
    </MudStack>

    <MudGrid>
        <!-- Details Card -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Details</MudText>
                <MudStack Spacing="3">
                    @if (!string.IsNullOrEmpty(_app.Address))
                    {
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Address</MudText>
                            <MudText Typo="Typo.body2">@_app.Address</MudText>
                        </MudStack>
                    }
                    @if (!string.IsNullOrEmpty(_app.ContactPerson))
                    {
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Contact Person</MudText>
                            <MudText Typo="Typo.body2">@_app.ContactPerson</MudText>
                        </MudStack>
                    }
                    @if (!string.IsNullOrEmpty(_app.ContactNumber))
                    {
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Contact Number</MudText>
                            <MudText Typo="Typo.body2">@_app.ContactNumber</MudText>
                        </MudStack>
                    }
                    @if (!string.IsNullOrEmpty(_app.OfficialEmail))
                    {
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Official Email</MudText>
                            <MudText Typo="Typo.body2">@_app.OfficialEmail</MudText>
                        </MudStack>
                    }
                    @if (!string.IsNullOrEmpty(_app.Website))
                    {
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Website</MudText>
                            <MudLink Href="@_app.Website" Target="_blank" Typo="Typo.body2">@_app.Website</MudLink>
                        </MudStack>
                    }
                    @if (!string.IsNullOrEmpty(_app.RegistrationNumber))
                    {
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Registration Number</MudText>
                            <MudText Typo="Typo.body2">@_app.RegistrationNumber</MudText>
                        </MudStack>
                    }
                    <MudDivider />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Created</MudText>
                        <MudText Typo="Typo.body2">@_app.CreatedDate.ToString("MMM dd, yyyy HH:mm")</MudText>
                    </MudStack>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Last Modified</MudText>
                        <MudText Typo="Typo.body2">@_app.ModifiedDate.ToString("MMM dd, yyyy HH:mm")</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Users Card -->
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">Users</MudText>
                    @if (IsAdmin || IsClinicAdminForApp)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.PersonAdd"
                                   OnClick="OpenInviteDialog">
                            Invite User
                        </MudButton>
                    }
                </MudStack>

                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-3" ActivePanelIndexChanged="OnTabChanged">
                    <MudTabPanel Text="@($"Active ({_users?.Count ?? 0})")" Icon="@Icons.Material.Filled.People">
                        @if (_usersLoading)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_users is not null)
                        {
                            <MudTable Items="@_users" Hover="true" Dense="true" Elevation="0">
                                <HeaderContent>
                                    <MudTh>Name</MudTh>
                                    <MudTh>Email</MudTh>
                                    <MudTh>Role</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh Style="width: 80px;"></MudTh>
                                </HeaderContent>
                                <RowTemplate Context="user">
                                    <MudTd DataLabel="Name">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudAvatar Size="Size.Small" Color="Color.Secondary">
                                                @(user.FirstName.Length > 0 ? user.FirstName[0] : '?')
                                            </MudAvatar>
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">@user.FullName</MudText>
                                                @if (user.IsOwner)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Primary">Owner</MudText>
                                                }
                                            </MudStack>
                                        </MudStack>
                                    </MudTd>
                                    <MudTd DataLabel="Email">
                                        <MudText Typo="Typo.body2">@user.EmailId</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Role">
                                        @if (!string.IsNullOrEmpty(user.RoleName))
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@user.RoleName</MudChip>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Status">
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(user.IsActive ? Color.Success : Color.Error)">
                                            @(user.IsActive ? "Active" : "Inactive")
                                        </MudChip>
                                    </MudTd>
                                    <MudTd>
                                        @if (!user.IsOwner && (IsAdmin || IsClinicAdminForApp))
                                        {
                                            <MudStack Row="true" Spacing="0">
                                                <MudTooltip Text="@(user.IsActive ? "Deactivate user" : "Activate user")">
                                                    <MudIconButton Icon="@(user.IsActive ? Icons.Material.Filled.PersonOff : Icons.Material.Filled.PersonAdd)"
                                                                   Color="@(user.IsActive ? Color.Warning : Color.Success)" Size="Size.Small"
                                                                   OnClick="@(() => ConfirmToggleUser(user))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Change role">
                                                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz"
                                                                   Color="Color.Info" Size="Size.Small"
                                                                   OnClick="@(() => OpenChangeRoleDialog(user))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Remove from application">
                                                    <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                                                   Color="Color.Error" Size="Size.Small"
                                                                   OnClick="@(() => ConfirmRemoveUser(user))" />
                                                </MudTooltip>
                                            </MudStack>
                                        }
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudText Color="Color.Secondary">No active users in this application.</MudText>
                                </NoRecordsContent>
                            </MudTable>
                        }
                    </MudTabPanel>

                    @if (IsAdmin || IsClinicAdminForApp)
                    {
                        <MudTabPanel Text="@($"Deactivated ({_deactivatedUsers?.Count ?? 0})")" Icon="@Icons.Material.Filled.PersonOff">
                            @if (_deactivatedUsersLoading)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (_deactivatedUsers is not null && _deactivatedUsers.Count > 0)
                            {
                                <MudTable Items="@_deactivatedUsers" Hover="true" Dense="true" Elevation="0">
                                    <HeaderContent>
                                        <MudTh>Name</MudTh>
                                        <MudTh>Email</MudTh>
                                        <MudTh>Last Role</MudTh>
                                        <MudTh Style="width: 120px;"></MudTh>
                                    </HeaderContent>
                                    <RowTemplate Context="user">
                                        <MudTd DataLabel="Name">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudAvatar Size="Size.Small" Color="Color.Default">
                                                    @(string.IsNullOrEmpty(user.FirstName) ? '?' : user.FirstName[0])
                                                </MudAvatar>
                                                <MudText Typo="Typo.body2">@user.FullName</MudText>
                                            </MudStack>
                                        </MudTd>
                                        <MudTd DataLabel="Email">
                                            <MudText Typo="Typo.body2">@user.EmailId</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="Last Role">
                                            @if (!string.IsNullOrEmpty(user.RoleName))
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@user.RoleName</MudChip>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                                            }
                                        </MudTd>
                                        <MudTd>
                                            <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.PersonAdd"
                                                       OnClick="@(() => ConfirmReactivateUser(user))">
                                                Re-Activate
                                            </MudButton>
                                        </MudTd>
                                    </RowTemplate>
                                    <NoRecordsContent>
                                        <MudText Color="Color.Secondary">No deactivated users.</MudText>
                                    </NoRecordsContent>
                                </MudTable>
                            }
                            else
                            {
                                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 3rem;" />
                                    <MudText Color="Color.Secondary">No deactivated users in this application.</MudText>
                                </MudStack>
                            }
                        </MudTabPanel>
                    }
                </MudTabs>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

<!-- Invite / Add User Dialog -->
<MudDialog @bind-Visible="_inviteDialogVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Add User to Application</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <!-- Step 1: Email Search -->
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Search for an existing user by email, or invite a new user.
        </MudText>
        <MudTextField @bind-Value="_searchEmail"
                      Label="Email Address" Placeholder="Type at least 2 characters to search..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      DebounceInterval="300"
                      OnDebounceIntervalElapsed="OnSearchEmailChanged" />

        @if (_searching)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2" />
        }

        @if (_searchResults is not null && _searchResults.Count > 0 && !_existingUserSelected)
        {
            <MudList T="UserSearchResultDto" Class="mt-2" Dense="true" Style="max-height: 200px; overflow-y: auto;">
                @foreach (var user in _searchResults)
                {
                    <MudListItem T="UserSearchResultDto" OnClick="@(() => SelectExistingUser(user))">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Small" Color="Color.Secondary">@(string.IsNullOrEmpty(user.FirstName) ? '?' : user.FirstName[0])</MudAvatar>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2"><b>@user.FullName</b></MudText>
                                <MudText Typo="Typo.caption">@user.EmailId</MudText>
                            </MudStack>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        }
        else if (_searchResults is not null && _searchResults.Count == 0 && _searchEmail?.Length >= 2 && !_searching && !_existingUserSelected)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true">
                No existing user found. You can send a new invitation below.
            </MudAlert>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-1"
                       OnClick="SwitchToNewInvite" StartIcon="@Icons.Material.Filled.Email">
                Send a new invitation to "@_searchEmail"
            </MudButton>
        }

        <!-- Selected existing user display -->
        @if (_existingUserSelected && _selectedExistingUser is not null)
        {
            <MudPaper Class="pa-3 mt-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudAvatar Color="Color.Primary" Size="Size.Small">@(string.IsNullOrEmpty(_selectedExistingUser.FirstName) ? '?' : _selectedExistingUser.FirstName[0])</MudAvatar>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2"><b>@_selectedExistingUser.FullName</b></MudText>
                            <MudText Typo="Typo.caption">@_selectedExistingUser.EmailId</MudText>
                        </MudStack>
                    </MudStack>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="ClearSelectedUser" />
                </MudStack>
            </MudPaper>
            <MudItem xs="12" Class="mt-3">
                <MudSelect T="Guid" @bind-Value="_selectedRoleId" Label="Role" Required="true" RequiredError="Role is required." Variant="Variant.Outlined" Disabled="_rolesLoading || _roles.Count == 0">
                    @if (_rolesLoading)
                    {
                        <MudSelectItem Value="@Guid.Empty">Loading roles...</MudSelectItem>
                    }
                    else if (_roles.Count == 0)
                    {
                        <MudSelectItem Value="@Guid.Empty">No roles available</MudSelectItem>
                    }
                    else
                    {
                        @foreach (var role in _roles)
                        {
                            <MudSelectItem Value="@role.RoleId">@role.RoleName</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
        }

        <!-- New invitation form -->
        @if (_showNewInviteForm)
        {
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">New User Invitation</MudText>
            <MudForm @ref="_inviteForm" @bind-IsValid="_inviteFormValid">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_inviteModel.FirstName"
                                      Label="First Name" Required="true"
                                      RequiredError="First name is required."
                                      Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_inviteModel.LastName"
                                      Label="Last Name" Required="true"
                                      RequiredError="Last name is required."
                                      Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_inviteModel.EmailId"
                                      Label="Email Address" Required="true"
                                      RequiredError="Email is required."
                                      InputType="InputType.Email"
                                      Variant="Variant.Outlined" ReadOnly="true" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_inviteModel.MobileNo"
                                      Label="Mobile Number"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSelect T="Guid" @bind-Value="_selectedRoleId" Label="Role" Required="true" RequiredError="Role is required." Variant="Variant.Outlined" Disabled="_rolesLoading || _roles.Count == 0">
                            @if (_rolesLoading)
                            {
                                <MudSelectItem Value="@Guid.Empty">Loading roles...</MudSelectItem>
                            }
                            else if (_roles.Count == 0)
                            {
                                <MudSelectItem Value="@Guid.Empty">No roles available</MudSelectItem>
                            }
                            else
                            {
                                @foreach (var role in _roles)
                                {
                                    <MudSelectItem Value="@role.RoleId">@role.RoleName</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseInviteDialog">Cancel</MudButton>
        @if (_existingUserSelected)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="AddExistingUserAsync" Disabled="_inviting || _selectedRoleId == Guid.Empty">
                @if (_inviting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Adding...</span>
                }
                else
                {
                    <span>Add User</span>
                }
            </MudButton>
        }
        else if (_showNewInviteForm)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="InviteNewUserAsync" Disabled="_inviting">
                @if (_inviting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Sending...</span>
                }
                else
                {
                    <span>Send Invitation</span>
                }
            </MudButton>
        }
    </DialogActions>
</MudDialog>

<!-- Remove User Confirmation -->
<MudDialog @bind-Visible="_removeUserDialogVisible">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
            <MudText Typo="Typo.h6">Remove User</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to remove <b>@_userToRemove?.FullName</b> from this application?</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">They will lose access immediately.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _removeUserDialogVisible = false)">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="RemoveUserAsync">Remove</MudButton>
    </DialogActions>
</MudDialog>

<!-- Toggle Application Status Confirmation -->
<MudDialog @bind-Visible="_toggleAppStatusDialogVisible">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="@(_isAppActive ? Color.Error : Color.Success)" />
            <MudText Typo="Typo.h6">@(_isAppActive ? "Deactivate" : "Activate") Application</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_isAppActive)
        {
            <MudText>Are you sure you want to <b>deactivate</b> this application?</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">Users will lose access until it is reactivated.</MudText>
        }
        else
        {
            <MudText>Are you sure you want to <b>activate</b> this application?</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _toggleAppStatusDialogVisible = false)">Cancel</MudButton>
        <MudButton Color="@(_isAppActive ? Color.Error : Color.Success)" Variant="Variant.Filled"
                   OnClick="ConfirmToggleApplicationStatus" Disabled="_togglingAppStatus">
            @if (_togglingAppStatus)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(_isAppActive ? "Deactivate" : "Activate")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Toggle User Status Confirmation -->
<MudDialog @bind-Visible="_toggleUserStatusDialogVisible">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="@(_userToToggle?.IsActive == true ? Color.Warning : Color.Success)" />
            <MudText Typo="Typo.h6">@(_userToToggle?.IsActive == true ? "Deactivate" : "Activate") User</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_userToToggle?.IsActive == true)
        {
            <MudText>Are you sure you want to <b>deactivate</b> <b>@_userToToggle?.FullName</b>?</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">They will lose access to this application until reactivated.</MudText>
        }
        else
        {
            <MudText>Are you sure you want to <b>activate</b> <b>@_userToToggle?.FullName</b>?</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _toggleUserStatusDialogVisible = false)">Cancel</MudButton>
        <MudButton Color="@(_userToToggle?.IsActive == true ? Color.Warning : Color.Success)" Variant="Variant.Filled"
                   OnClick="ConfirmToggleUserStatus">
            @(_userToToggle?.IsActive == true ? "Deactivate" : "Activate")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Change Role Dialog -->
<MudDialog @bind-Visible="_changeRoleDialogVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Info" />
            <MudText Typo="Typo.h6">Change Role</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-3">Change role for <b>@_userToChangeRole?.FullName</b></MudText>
        <MudSelect T="Guid" @bind-Value="_newRoleId" Label="New Role" Variant="Variant.Outlined"
                   Disabled="_roles.Count == 0">
            @foreach (var role in _roles)
            {
                <MudSelectItem Value="@role.RoleId">@role.RoleName</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _changeRoleDialogVisible = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="ChangeUserRoleAsync" Disabled="_changingRole || _newRoleId == Guid.Empty">
            @if (_changingRole)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Changing...</span>
            }
            else
            {
                <span>Change Role</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Re-Activate User Confirmation -->
<MudDialog @bind-Visible="_reactivateUserDialogVisible">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Success" />
            <MudText Typo="Typo.h6">Re-Activate User</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to <b>re-activate</b> <b>@_userToReactivate?.FullName</b>?</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">They will regain access to this application.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _reactivateUserDialogVisible = false)">Cancel</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="ReactivateUserAsync" Disabled="_reactivatingUser">
            @if (_reactivatingUser)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Re-Activating...</span>
            }
            else
            {
                <span>Re-Activate</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private bool _notFound;
    private bool _usersLoading = true;
    private ApplicationResponseDto? _app;
    private List<ApplicationUserResponseDto>? _users;

    // Invite / Add user dialog
    private bool _inviteDialogVisible;
    private bool _inviting;
    private MudForm _inviteForm = null!;
    private bool _inviteFormValid;
    private InviteUserRequestDto _inviteModel = new();
    private Guid _selectedRoleId = Guid.Empty;
    private List<RoleResponseDto> _roles = new();
    private bool _rolesLoading = false;

    // Email search for existing users
    private string? _searchEmail;
    private bool _searching;
    private List<UserSearchResultDto>? _searchResults;
    private bool _existingUserSelected;
    private UserSearchResultDto? _selectedExistingUser;
    private bool _showNewInviteForm;

    // Remove user dialog
    private bool _removeUserDialogVisible;
    private ApplicationUserResponseDto? _userToRemove;

    // Toggle application status
    private bool _togglingAppStatus;
    private bool _isAppActive => _app?.IsActive ?? false;
    private bool _toggleAppStatusDialogVisible;

    // Toggle user status
    private bool _toggleUserStatusDialogVisible;
    private ApplicationUserResponseDto? _userToToggle;

    // Change role dialog
    private bool _changeRoleDialogVisible;
    private bool _changingRole;
    private ApplicationUserResponseDto? _userToChangeRole;
    private Guid _newRoleId = Guid.Empty;

    // Deactivated users
    private List<ApplicationUserResponseDto>? _deactivatedUsers;
    private bool _deactivatedUsersLoading;
    private bool _deactivatedUsersLoaded;

    // Re-activate user
    private bool _reactivateUserDialogVisible;
    private bool _reactivatingUser;
    private ApplicationUserResponseDto? _userToReactivate;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadApplicationAsync(), LoadUsersAsync(), LoadAndCacheRolesAsync());
    }

    private async Task LoadApplicationAsync()
    {
        try
        {
            var result = await AppClient.GetApplicationByIdAsync(Id);
            if (!result.Success || result.Data is null)
                _notFound = true;
            else
                _app = result.Data;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading application: {ex.Message}", Severity.Error);
            _notFound = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadUsersAsync()
    {
        try
        {
            var result = await AppClient.GetApplicationUsersAsync(Id);
            _users = result.Success ? result.Data ?? [] : [];
        }
        catch
        {
            _users = [];
        }
        finally
        {
            _usersLoading = false;
        }
    }

    // ── Invite / Add User ──

    private void OpenInviteDialog()
    {
        _searchEmail = null;
        _searchResults = null;
        _existingUserSelected = false;
        _selectedExistingUser = null;
        _showNewInviteForm = false;
        _inviteModel = new InviteUserRequestDto();
        _selectedRoleId = _roles.Count > 0 ? _roles[0].RoleId : Guid.Empty;
        _inviteDialogVisible = true;
    }

    private void CloseInviteDialog()
    {
        _inviteDialogVisible = false;
        _searchEmail = null;
        _searchResults = null;
        _existingUserSelected = false;
        _selectedExistingUser = null;
        _showNewInviteForm = false;
    }

    private async Task OnSearchEmailChanged(string value)
    {
        _searchEmail = value;
        _existingUserSelected = false;
        _selectedExistingUser = null;
        _showNewInviteForm = false;

        if (string.IsNullOrWhiteSpace(value) || value.Length < 2)
        {
            _searchResults = null;
            return;
        }

        _searching = true;
        StateHasChanged();

        try
        {
            var result = await AuthClient.SearchUsersByEmailAsync(value);
            _searchResults = result.Success ? result.Data ?? [] : [];
        }
        catch
        {
            _searchResults = [];
        }
        finally
        {
            _searching = false;
            StateHasChanged();
        }
    }

    private void SelectExistingUser(UserSearchResultDto user)
    {
        _selectedExistingUser = user;
        _existingUserSelected = true;
        _searchResults = null;
        _showNewInviteForm = false;
        _selectedRoleId = _roles.Count > 0 ? _roles[0].RoleId : Guid.Empty;
        StateHasChanged();
    }

    private void ClearSelectedUser()
    {
        _existingUserSelected = false;
        _selectedExistingUser = null;
        _searchEmail = null;
        _searchResults = null;
    }

    private void SwitchToNewInvite()
    {
        _showNewInviteForm = true;
        _existingUserSelected = false;
        _selectedExistingUser = null;
        _inviteModel = new InviteUserRequestDto { EmailId = _searchEmail ?? string.Empty };
        _selectedRoleId = _roles.Count > 0 ? _roles[0].RoleId : Guid.Empty;
    }

    private async Task AddExistingUserAsync()
    {
        if (_selectedExistingUser is null || AuthState.CurrentUser is null || _selectedRoleId == Guid.Empty) return;

        _inviting = true;
        try
        {
            var request = new InviteExistingUserRequestDto
            {
                UserId = _selectedExistingUser.UserId,
                ApplicationId = Id,
                RoleId = _selectedRoleId
            };
            var result = await AppClient.InviteExistingUserAsync(AuthState.CurrentUser.UserId, request);
            if (result.Success)
            {
                Snackbar.Add(result.Message ?? $"Invitation sent to {_selectedExistingUser.FullName}. They will be added once they accept.", Severity.Success);
                CloseInviteDialog();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Failed to add user.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error adding user: {ex.Message}", Severity.Error);
        }
        finally
        {
            _inviting = false;
        }
    }

    private async Task InviteNewUserAsync()
    {
        await _inviteForm.Validate();
        if (!_inviteFormValid) return;

        if (_selectedRoleId == Guid.Empty)
        {
            Snackbar.Add("Please select a valid role.", Severity.Error);
            return;
        }

        if (AuthState.CurrentUser is null) return;

        _inviteModel.ApplicationId = Id;
        _inviteModel.RoleId = _selectedRoleId;
        _inviting = true;

        try
        {
            var result = await AppClient.InviteUserAsync(AuthState.CurrentUser.UserId, _inviteModel);
            if (result.Success)
            {
                Snackbar.Add($"Invitation sent to {_inviteModel.EmailId}.", Severity.Success);
                CloseInviteDialog();
                await LoadUsersAsync();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Failed to send invitation.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error sending invitation: {ex.Message}", Severity.Error);
        }
        finally
        {
            _inviting = false;
        }
    }

    private async Task LoadAndCacheRolesAsync()
    {
        _rolesLoading = true;
        try
        {
            var cached = RoleCache.GetRoles(Id);
            if (cached != null && cached.Count > 0)
            {
                _roles = cached;
                _selectedRoleId = _roles[0].RoleId;
            }
            else
            {
                var result = await AppClient.GetRolesByApplicationAsync(Id);
                _roles = result.Success && result.Data != null ? result.Data.Roles : new List<RoleResponseDto>();
                if (_roles.Count > 0)
                {
                    RoleCache.SetRoles(Id, _roles);
                    _selectedRoleId = _roles[0].RoleId;
                }
                else
                {
                    _selectedRoleId = Guid.Empty;
                }
            }
        }
        catch
        {
            _roles = new List<RoleResponseDto>();
            _selectedRoleId = Guid.Empty;
        }
        finally
        {
            _rolesLoading = false;
        }
    }

    // ── Remove User ──

    private void ConfirmRemoveUser(ApplicationUserResponseDto user)
    {
        _userToRemove = user;
        _removeUserDialogVisible = true;
    }

    private async Task RemoveUserAsync()
    {
        if (_userToRemove is null || AuthState.CurrentUser is null) return;

        try
        {
            var result = await AppClient.RemoveUserFromApplicationAsync(Id, _userToRemove.UserId, AuthState.CurrentUser.UserId);
            if (result.Success)
            {
                Snackbar.Add($"{_userToRemove.FullName} removed from application.", Severity.Success);
                _removeUserDialogVisible = false;
                _userToRemove = null;
                await LoadUsersAsync();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Failed to remove user.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error removing user: {ex.Message}", Severity.Error);
        }
    }

    // ── Toggle Application Status (with confirmation) ──

    private async Task ConfirmToggleApplicationStatus()
    {
        if (_app is null || AuthState.CurrentUser is null) return;

        _togglingAppStatus = true;
        try
        {
            var newStatus = !_isAppActive;
            var request = new ToggleStatusRequestDto { IsActive = newStatus };
            var result = await AppClient.ToggleApplicationStatusAsync(Id, AuthState.CurrentUser.UserId, request);
            if (result.Success)
            {
                Snackbar.Add(result.Message ?? (newStatus ? "Application activated." : "Application deactivated."), Severity.Success);
                _toggleAppStatusDialogVisible = false;
                await LoadApplicationAsync();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Failed to toggle application status.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error toggling status: {ex.Message}", Severity.Error);
        }
        finally
        {
            _togglingAppStatus = false;
        }
    }

    // ── Toggle User Status (with confirmation) ──

    private void ConfirmToggleUser(ApplicationUserResponseDto user)
    {
        _userToToggle = user;
        _toggleUserStatusDialogVisible = true;
    }

    private async Task ConfirmToggleUserStatus()
    {
        if (_userToToggle is null || AuthState.CurrentUser is null) return;

        try
        {
            var newStatus = !_userToToggle.IsActive;
            var request = new ToggleStatusRequestDto { IsActive = newStatus };
            var result = await AppClient.ToggleUserApplicationMappingAsync(Id, _userToToggle.UserId, AuthState.CurrentUser.UserId, request);
            if (result.Success)
            {
                Snackbar.Add(result.Message ?? (newStatus ? $"{_userToToggle.FullName} activated." : $"{_userToToggle.FullName} deactivated."), Severity.Success);
                _toggleUserStatusDialogVisible = false;
                _userToToggle = null;
                await LoadUsersAsync();
                if (_deactivatedUsersLoaded) await LoadDeactivatedUsersAsync();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Failed to toggle user status.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error toggling user status: {ex.Message}", Severity.Error);
        }
    }

    // ── Change Role ──

    private void OpenChangeRoleDialog(ApplicationUserResponseDto user)
    {
        _userToChangeRole = user;
        _newRoleId = user.RoleId ?? Guid.Empty;
        _changeRoleDialogVisible = true;
    }

    private async Task ChangeUserRoleAsync()
    {
        if (_userToChangeRole is null || AuthState.CurrentUser is null || _newRoleId == Guid.Empty) return;

        _changingRole = true;
        try
        {
            var request = new ChangeUserRoleRequestDto { NewRoleId = _newRoleId };
            var result = await AppClient.ChangeUserRoleAsync(Id, _userToChangeRole.UserId, AuthState.CurrentUser.UserId, request);
            if (result.Success)
            {
                Snackbar.Add(result.Message ?? "User role changed successfully.", Severity.Success);
                _changeRoleDialogVisible = false;
                _userToChangeRole = null;
                await LoadUsersAsync();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Failed to change user role.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error changing role: {ex.Message}", Severity.Error);
        }
        finally
        {
            _changingRole = false;
        }
    }

    // ── Deactivated Users ──

    private async Task OnTabChanged(int tabIndex)
    {
        // Tab 1 = Deactivated Users
        if (tabIndex == 1 && !_deactivatedUsersLoaded)
        {
            await LoadDeactivatedUsersAsync();
        }
    }

    private async Task LoadDeactivatedUsersAsync()
    {
        _deactivatedUsersLoading = true;
        StateHasChanged();
        try
        {
            var result = await AppClient.GetDeactivatedApplicationUsersAsync(Id);
            _deactivatedUsers = result.Success ? result.Data ?? [] : [];
            _deactivatedUsersLoaded = true;
        }
        catch
        {
            _deactivatedUsers = [];
        }
        finally
        {
            _deactivatedUsersLoading = false;
            StateHasChanged();
        }
    }

    private void ConfirmReactivateUser(ApplicationUserResponseDto user)
    {
        _userToReactivate = user;
        _reactivateUserDialogVisible = true;
    }

    private async Task ReactivateUserAsync()
    {
        if (_userToReactivate is null || AuthState.CurrentUser is null) return;

        _reactivatingUser = true;
        try
        {
            var request = new ToggleStatusRequestDto { IsActive = true };
            var result = await AppClient.ToggleUserApplicationMappingAsync(Id, _userToReactivate.UserId, AuthState.CurrentUser.UserId, request);
            if (result.Success)
            {
                Snackbar.Add(result.Message ?? $"{_userToReactivate.FullName} has been re-activated.", Severity.Success);
                _reactivateUserDialogVisible = false;
                _userToReactivate = null;
                // Refresh both lists
                await Task.WhenAll(LoadUsersAsync(), LoadDeactivatedUsersAsync());
                StateHasChanged();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Failed to re-activate user.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error re-activating user: {ex.Message}", Severity.Error);
        }
        finally
        {
            _reactivatingUser = false;
        }
    }

    // ── Helpers ──

    private static string GetTypeName(int type) => type switch
    {
        0 => "Clinic",
        1 => "School",
        2 => "HR Management",
        _ => "Unknown"
    };

    private static Color GetTypeColor(int type) => type switch
    {
        0 => Color.Success,
        1 => Color.Info,
        2 => Color.Warning,
        _ => Color.Default
    };

    private bool IsAdmin => AuthState.CurrentUser?.UserRoles.Any(r => r.RoleName == "Admin" && r.IsActive) == true;
    private bool IsClinicAdminForApp {
        get {
            if (_app == null || _users == null || AuthState.CurrentUser == null)
                return false;
            var currentUser = _users.FirstOrDefault(u => u.EmailId == AuthState.CurrentUser.EmailId);
            return currentUser != null &&
                string.Equals(currentUser.RoleName, "Clinic Admin", StringComparison.OrdinalIgnoreCase) &&
                currentUser.IsActive;
        }
    }
}
