@page "/applications/{Id:guid}/edit"
@layout AuthorizedLayout
@inject IApplicationApiClient AppClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Application - TenantCore</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => NavigationManager.NavigateTo($"/applications/{Id}"))" />
    <MudText Typo="Typo.h4">Edit Application</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_notFound)
{
    <MudPaper Class="pa-6" Elevation="2">
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Warning" Style="font-size: 4rem;" />
            <MudText Typo="Typo.h5">Application Not Found</MudText>
            <MudText Color="Color.Secondary">The application you're looking for doesn't exist.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/applications">Back to Applications</MudButton>
        </MudStack>
    </MudPaper>
}
else if (_loaded)
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-6" Elevation="2">
                <MudForm @ref="_form" @bind-IsValid="_formValid">
                    <MudText Typo="Typo.h6" Class="mb-4">Basic Information</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.ApplicationName"
                                          Label="Application Name"
                                          Required="true"
                                          RequiredError="Application name is required."
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Apps" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.ApplicationCode"
                                          Label="Application Code"
                                          Required="true"
                                          RequiredError="Application code is required."
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Tag" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="int" @bind-Value="_model.ApplicationType"
                                       Label="Application Type"
                                       Variant="Variant.Outlined">
                                <MudSelectItem Value="0">Clinic</MudSelectItem>
                                <MudSelectItem Value="1">School</MudSelectItem>
                                <MudSelectItem Value="2">HR Management</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.RegistrationNumber"
                                          Label="Registration Number"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Numbers" />
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" Class="mb-4">Contact Information</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.ContactPerson"
                                          Label="Contact Person"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Person" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.ContactNumber"
                                          Label="Contact Number"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Phone" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.OfficialEmail"
                                          Label="Official Email"
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Email" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Website"
                                          Label="Website"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Language" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_model.Address"
                                          Label="Address"
                                          Lines="2"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.LocationOn" />
                        </MudItem>
                    </MudGrid>

                    <MudStack Row="true" Spacing="2" Class="mt-6" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Text"
                                   OnClick="@(() => NavigationManager.NavigateTo($"/applications/{Id}"))">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="SubmitAsync"
                                   Disabled="_submitting"
                                   StartIcon="@(_submitting ? null : Icons.Material.Filled.Save)">
                            @if (_submitting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Saving...</span>
                            }
                            else
                            {
                                <span>Save Changes</span>
                            }
                        </MudButton>
                    </MudStack>
                </MudForm>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Application Info</MudText>
                <MudStack Spacing="2">
                    <MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Application ID</MudText>
                        <MudText Typo="Typo.body2" Style="word-break: break-all;">@Id</MudText>
                    </MudStack>
                    <MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Created</MudText>
                        <MudText Typo="Typo.body2">@_original?.CreatedDate.ToString("MMM dd, yyyy HH:mm")</MudText>
                    </MudStack>
                    <MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Last Modified</MudText>
                        <MudText Typo="Typo.body2">@_original?.ModifiedDate.ToString("MMM dd, yyyy HH:mm")</MudText>
                    </MudStack>
                    <MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Role</MudText>
                        @if (_original?.IsOwner == true)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.Star">Owner</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Member</MudChip>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MudForm _form = null!;
    private bool _formValid;
    private bool _loading = true;
    private bool _loaded;
    private bool _notFound;
    private bool _submitting;
    private ApplicationResponseDto? _original;
    private ApplicationCreationRequestDto _model = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await AppClient.GetApplicationByIdAsync(Id);
            if (!result.Success || result.Data is null)
            {
                _notFound = true;
                return;
            }

            _original = result.Data;
            _model.ApplicationName = _original.ApplicationName;
            _model.ApplicationCode = _original.ApplicationCode;
            _model.ApplicationType = _original.ApplicationType;
            _model.Address = _original.Address;
            _model.ContactNumber = _original.ContactNumber;
            _model.ContactPerson = _original.ContactPerson;
            _model.RegistrationNumber = _original.RegistrationNumber;
            _model.OfficialEmail = _original.OfficialEmail;
            _model.Website = _original.Website;
            _model.AdditionalInfo = _original.AdditionalInfo;
            _loaded = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading application: {ex.Message}", Severity.Error);
            _notFound = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_formValid) return;

        _submitting = true;
        try
        {
            var result = await AppClient.EditApplicationAsync(Id, _model);
            if (result.Success)
            {
                Snackbar.Add("Application updated successfully.", Severity.Success);
                NavigationManager.NavigateTo($"/applications/{Id}");
            }
            else
            {
                Snackbar.Add(result.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating application: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }
}
