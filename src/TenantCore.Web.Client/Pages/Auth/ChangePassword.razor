@page "/auth/change-password"
@layout AuthorizedLayout
@inject IAuthApiClient AuthClient
@inject AuthStateService AuthState
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Change Password - TenantCore</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Change Password</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Elevation="2" Class="pa-6">
            <MudStack AlignItems="AlignItems.Center" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h6">Update Your Password</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Enter your current password and choose a new one
                </MudText>
            </MudStack>

            <EditForm Model="_model" OnValidSubmit="HandleChangePassword">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_model.CurrentPassword"
                              Label="Current Password"
                              Variant="Variant.Outlined"
                              InputType="@(_showCurrentPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showCurrentPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="@(() => _showCurrentPassword = !_showCurrentPassword)"
                              For="@(() => _model.CurrentPassword)"
                              Disabled="_loading"
                              Class="mb-4" />

                <MudTextField @bind-Value="_model.NewPassword"
                              Label="New Password"
                              Variant="Variant.Outlined"
                              InputType="@(_showNewPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showNewPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="@(() => _showNewPassword = !_showNewPassword)"
                              For="@(() => _model.NewPassword)"
                              Disabled="_loading"
                              Class="mb-4"
                              HelperText="At least 8 characters" />

                <MudTextField @bind-Value="_model.ConfirmPassword"
                              Label="Confirm New Password"
                              Variant="Variant.Outlined"
                              InputType="@(_showNewPassword ? InputType.Text : InputType.Password)"
                              For="@(() => _model.ConfirmPassword)"
                              Disabled="_loading"
                              Class="mb-4" />

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true" Variant="Variant.Filled">
                        @_errorMessage
                    </MudAlert>
                }

                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                    <MudButton Variant="Variant.Text" Color="Color.Secondary" Href="/auth/profile"
                               Disabled="_loading">
                        Cancel
                    </MudButton>
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="_loading"
                               Style="text-transform: none;">
                        @if (_loading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Surface" Class="mr-2" />
                            <span>Changing...</span>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Save" Class="mr-2" />
                            <span>Change Password</span>
                        }
                    </MudButton>
                </MudStack>
            </EditForm>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private ChangePasswordRequestDto _model = new();
    private bool _loading;
    private bool _showCurrentPassword;
    private bool _showNewPassword;
    private string? _errorMessage;

    private async Task HandleChangePassword()
    {
        if (AuthState.CurrentUser == null)
        {
            _errorMessage = "You must be logged in to change your password.";
            return;
        }

        _loading = true;
        _errorMessage = null;

        try
        {
            var response = await AuthClient.ChangePasswordAsync(AuthState.CurrentUser.UserId, _model);

            if (response.Success)
            {
                Snackbar.Add("Password changed successfully!", Severity.Success);
                NavigationManager.NavigateTo("/auth/profile");
            }
            else
            {
                _errorMessage = response.Message ?? "Failed to change password. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
            Console.WriteLine($"Change password error: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
