@page "/auth/profile"
@layout AuthorizedLayout
@inject AuthStateService AuthState
@inject IAuthApiClient AuthClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Profile - TenantCore</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Profile</MudText>

@if (AuthState.CurrentUser != null)
{
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-6">
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudAvatar Size="Size.Large" Color="Color.Primary" Style="width: 100px; height: 100px; font-size: 2.5rem;">
                        @(AuthState.CurrentUser.FirstName[0])@(AuthState.CurrentUser.LastName[0])
                    </MudAvatar>
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.h5">@AuthState.CurrentUser.FullName</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@AuthState.CurrentUser.EmailId</MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="1">
                        <MudChip T="string" Color="@(AuthState.CurrentUser.IsActive ? Color.Success : Color.Error)" 
                                 Size="Size.Small" Variant="Variant.Filled">
                            @(AuthState.CurrentUser.IsActive ? "Active" : "Inactive")
                        </MudChip>
                        <MudChip T="string" Color="@(AuthState.CurrentUser.IsEmailVerified ? Color.Success : Color.Warning)" 
                                 Size="Size.Small" Variant="Variant.Outlined">
                            @(AuthState.CurrentUser.IsEmailVerified ? "Verified" : "Unverified")
                        </MudChip>
                    </MudStack>
                    <MudStack Row="true" Spacing="1">
                        @foreach (var role in AuthState.CurrentUser.UserRoles.Where(r => r.IsActive))
                        {
                            <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Filled">@role.RoleName</MudChip>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudPaper Elevation="2" Class="pa-6">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                    <MudText Typo="Typo.h6">Account Information</MudText>
                    @if (!_editingProfile)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Edit" OnClick="StartEditProfile">
                            Edit Profile
                        </MudButton>
                    }
                </MudStack>

                @if (_editingProfile)
                {
                    <EditForm Model="_profileModel" OnValidSubmit="SaveProfile">
                        <DataAnnotationsValidator />
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_profileModel.FirstName"
                                              Label="First Name"
                                              Variant="Variant.Outlined"
                                              For="@(() => _profileModel.FirstName)"
                                              Disabled="_savingProfile" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_profileModel.MiddleName"
                                              Label="Middle Name"
                                              Variant="Variant.Outlined"
                                              Disabled="_savingProfile" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_profileModel.LastName"
                                              Label="Last Name"
                                              Variant="Variant.Outlined"
                                              For="@(() => _profileModel.LastName)"
                                              Disabled="_savingProfile" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_profileModel.MobileNo"
                                              Label="Mobile Number"
                                              Variant="Variant.Outlined"
                                              Disabled="_savingProfile" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                                    <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="CancelEditProfile"
                                               Disabled="_savingProfile">
                                        Cancel
                                    </MudButton>
                                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                                               Disabled="_savingProfile">
                                        @if (_savingProfile)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Surface" Class="mr-2" />
                                            <span>Saving...</span>
                                        }
                                        else
                                        {
                                            <span>Save Changes</span>
                                        }
                                    </MudButton>
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </EditForm>
                }
                else
                {
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">First Name</MudText>
                                <MudText>@AuthState.CurrentUser.FirstName</MudText>
                            </MudStack>
                        </MudItem>
                        @if (!string.IsNullOrEmpty(AuthState.CurrentUser.MiddleName))
                        {
                            <MudItem xs="12" sm="6">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Middle Name</MudText>
                                    <MudText>@AuthState.CurrentUser.MiddleName</MudText>
                                </MudStack>
                            </MudItem>
                        }
                        <MudItem xs="12" sm="6">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Last Name</MudText>
                                <MudText>@AuthState.CurrentUser.LastName</MudText>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText>@AuthState.CurrentUser.EmailId</MudText>
                                    @if (AuthState.CurrentUser.IsEmailVerified)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Success" Size="Size.Small" />
                                    }
                                </MudStack>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Mobile Number</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText>@(AuthState.CurrentUser.MobileNo ?? "Not provided")</MudText>
                                    @if (AuthState.CurrentUser.IsMobileVerified)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Success" Size="Size.Small" />
                                    }
                                </MudStack>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Member Since</MudText>
                                <MudText>@AuthState.CurrentUser.CreatedDate.ToString("MMMM dd, yyyy")</MudText>
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                }
            </MudPaper>

            @if (AuthState.CurrentUser.UserApplications.Any())
            {
                <MudPaper Elevation="2" Class="pa-6 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-4">Applications</MudText>
                    <MudTable Items="AuthState.CurrentUser.UserApplications" Dense="true" Hover="true">
                        <HeaderContent>
                            <MudTh>Application</MudTh>
                            <MudTh>Role</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="app">
                            <MudTd>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText>@app.ApplicationName</MudText>
                                    @if (app.IsOwner)
                                    {
                                        <MudChip T="string" Color="Color.Primary" Size="Size.Small">Owner</MudChip>
                                    }
                                </MudStack>
                            </MudTd>
                            <MudTd>
                                @{
                                    var roles = AuthState.CurrentUser.UserRoles
                                        .Where(r => r.ApplicationId == app.ApplicationId)
                                        .Select(r => r.RoleName);
                                }
                                @string.Join(", ", roles)
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Color="@(app.IsActive ? Color.Success : Color.Error)" 
                                         Size="Size.Small" Variant="Variant.Text">
                                    @(app.IsActive ? "Active" : "Inactive")
                                </MudChip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            }

            <MudPaper Elevation="2" Class="pa-6 mt-4">
                <MudText Typo="Typo.h6" Class="mb-4">Security</MudText>
                <MudStack Spacing="3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Two-Factor Authentication</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Add an extra layer of security to your account
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudChip T="string" Color="@(_isTwoFactorEnabled ? Color.Success : Color.Default)"
                                     Size="Size.Small" Variant="Variant.Filled">
                                @(_isTwoFactorEnabled ? "Enabled" : "Disabled")
                            </MudChip>
                            @if (_isTwoFactorEnabled)
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => _disable2faDialogVisible = true)"
                                           Disabled="_processing2fa">
                                    Disable
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                           OnClick="InitiateEnable2faAsync"
                                           Disabled="_processing2fa">
                                    @if (_processing2fa)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                    }
                                    Enable
                                </MudButton>
                            }
                        </MudStack>
                    </MudStack>
                    <MudDivider />
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Change Password</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Update your account password
                            </MudText>
                        </MudStack>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   Href="/auth/change-password">
                            Change
                        </MudButton>
                    </MudStack>
                    <MudDivider />
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Sign Out All Devices</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Sign out from all sessions on all devices
                            </MudText>
                        </MudStack>
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                   OnClick="@(() => _signOutAllDialogVisible = true)">
                            Sign Out All
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
else
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}

<!-- Sign Out All Confirmation -->
<MudDialog @bind-Visible="_signOutAllDialogVisible">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Sign Out All Devices</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to sign out from <b>all devices</b>?</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">You will need to log in again on every device.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _signOutAllDialogVisible = false)">Cancel</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="SignOutAllDevices">Sign Out All</MudButton>
    </DialogActions>
</MudDialog>

<!-- Enable 2FA Dialog -->
<MudDialog @bind-Visible="_enable2faDialogVisible"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = false })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Enable Two-Factor Authentication</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_enable2faStep == 1 && !string.IsNullOrEmpty(_enable2faQrCode))
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                    Scan this QR code with your authenticator app (e.g. Google Authenticator), then enter the 6-digit code below.
                </MudText>
                <MudPaper Elevation="2" Class="pa-3">
                    <img src="@($"data:image/png;base64,{_enable2faQrCode}")"
                         alt="2FA QR Code" style="width: 200px; height: 200px;" />
                </MudPaper>
                <MudTextField @bind-Value="_enable2faOtp"
                              Label="6-Digit Code"
                              Variant="Variant.Outlined"
                              InputType="InputType.Number"
                              MaxLength="6"
                              Placeholder="000000"
                              FullWidth="true"
                              Disabled="_processing2fa" />
                @if (!string.IsNullOrEmpty(_twoFaError))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_twoFaError</MudAlert>
                }
            </MudStack>
        }
        else if (string.IsNullOrEmpty(_enable2faQrCode))
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelEnable2fa" Disabled="_processing2fa">Cancel</MudButton>
        @if (_enable2faStep == 1)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="ConfirmEnable2faAsync"
                       Disabled="_processing2fa || _enable2faOtp.Length != 6">
                @if (_processing2fa)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Verify & Enable
            </MudButton>
        }
    </DialogActions>
</MudDialog>

<!-- Disable 2FA Dialog -->
<MudDialog @bind-Visible="_disable2faDialogVisible"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.SecurityUpdateWarning" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Disable Two-Factor Authentication</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Enter the current 6-digit code from your authenticator app to confirm.
        </MudText>
        <MudTextField @bind-Value="_disable2faOtp"
                      Label="6-Digit Code"
                      Variant="Variant.Outlined"
                      InputType="InputType.Number"
                      MaxLength="6"
                      Placeholder="000000"
                      FullWidth="true"
                      Disabled="_processing2fa" />
        @if (!string.IsNullOrEmpty(_twoFaError))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_twoFaError</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => { _disable2faDialogVisible = false; _disable2faOtp = string.Empty; _twoFaError = null; })"
                   Disabled="_processing2fa">
            Cancel
        </MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled"
                   OnClick="Disable2faAsync"
                   Disabled="_processing2fa || _disable2faOtp.Length != 6">
            @if (_processing2fa)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Disable 2FA
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _editingProfile;
    private bool _savingProfile;
    private bool _isTwoFactorEnabled;
    private bool _signOutAllDialogVisible;
    private UpdateUserProfileRequestDto _profileModel = new();

    private bool _enable2faDialogVisible;
    private bool _disable2faDialogVisible;
    private bool _processing2fa;
    private int _enable2faStep;
    private string _enable2faQrCode = string.Empty;
    private string _enable2faOtp = string.Empty;
    private string _disable2faOtp = string.Empty;
    private string? _twoFaError;

    protected override void OnInitialized()
    {
        if (AuthState.CurrentUser != null)
        {
            LoadTwoFactorStatus();
        }
    }

    private void LoadTwoFactorStatus()
    {
        if (AuthState.CurrentUser != null)
        {
            _isTwoFactorEnabled = AuthState.CurrentUser.IsTwoFactorEnabled;
        }
    }

    private void StartEditProfile()
    {
        if (AuthState.CurrentUser == null) return;
        _profileModel = new UpdateUserProfileRequestDto
        {
            FirstName = AuthState.CurrentUser.FirstName,
            MiddleName = AuthState.CurrentUser.MiddleName,
            LastName = AuthState.CurrentUser.LastName,
            MobileNo = AuthState.CurrentUser.MobileNo
        };
        _editingProfile = true;
    }

    private void CancelEditProfile()
    {
        _editingProfile = false;
    }

    private async Task SaveProfile()
    {
        if (AuthState.CurrentUser == null) return;

        _savingProfile = true;
        try
        {
            var response = await AuthClient.UpdateUserProfileAsync(AuthState.CurrentUser.UserId, _profileModel);
            if (response.Success && response.Data != null)
            {
                AuthState.UpdateUserProfile(response.Data);
                Snackbar.Add("Profile updated successfully!", Severity.Success);
                _editingProfile = false;
            }
            else
            {
                Snackbar.Add(response.Message ?? "Failed to update profile.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingProfile = false;
        }
    }

    private async Task SignOutAllDevices()
    {
        try
        {
            var response = await AuthClient.LogoutAllSessionsAsync();
            if (response.Success)
            {
                Snackbar.Add("Signed out from all devices.", Severity.Success);
                await AuthState.ClearAuthStateAsync();
                NavigationManager.NavigateTo("/auth/login", forceLoad: true);
            }
            else
            {
                Snackbar.Add(response.Message ?? "Failed to sign out.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task InitiateEnable2faAsync()
    {
        if (AuthState.CurrentUser is null) return;

        _processing2fa = true;
        _twoFaError = null;
        _enable2faQrCode = string.Empty;
        _enable2faStep = 0;
        _enable2faOtp = string.Empty;
        _enable2faDialogVisible = true;
        StateHasChanged();

        try
        {
            var response = await AuthClient.EnableTwoFactorAsync(AuthState.CurrentUser.UserId);
            if (response.Success && response.Data?.QrCodeBase64 is not null)
            {
                _enable2faQrCode = response.Data.QrCodeBase64;
                _enable2faStep = 1;
            }
            else
            {
                _twoFaError = response.Message ?? "Failed to initiate 2FA setup.";
            }
        }
        catch (Exception ex)
        {
            _twoFaError = $"Error: {ex.Message}";
        }
        finally
        {
            _processing2fa = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmEnable2faAsync()
    {
        if (AuthState.CurrentUser is null) return;

        _processing2fa = true;
        _twoFaError = null;
        StateHasChanged();

        try
        {
            var request = new ValidateTwoFactorRequestDto { OtpCode = _enable2faOtp };
            var response = await AuthClient.ConfirmEnableTwoFactorAsync(AuthState.CurrentUser.UserId, request);
            if (response.Success)
            {
                _enable2faDialogVisible = false;
                _enable2faOtp = string.Empty;
                _enable2faQrCode = string.Empty;
                await SyncUserProfileAsync();
                Snackbar.Add("Two-factor authentication enabled successfully.", Severity.Success);
            }
            else
            {
                _twoFaError = response.Message ?? "Invalid code. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _twoFaError = $"Error: {ex.Message}";
        }
        finally
        {
            _processing2fa = false;
            StateHasChanged();
        }
    }

    private async Task SyncUserProfileAsync()
    {
        if (AuthState.CurrentUser is null) return;
        try
        {
            var profile = await AuthClient.GetUserByIdAsync(AuthState.CurrentUser.UserId);
            if (profile.Success && profile.Data is not null)
            {
                AuthState.UpdateUserProfile(profile.Data);
                _isTwoFactorEnabled = profile.Data.IsTwoFactorEnabled;
            }
        }
        catch
        {
            _isTwoFactorEnabled = AuthState.CurrentUser.IsTwoFactorEnabled;
        }
    }

    private void CancelEnable2fa()
    {
        _enable2faDialogVisible = false;
        _enable2faOtp = string.Empty;
        _enable2faQrCode = string.Empty;
        _enable2faStep = 0;
        _twoFaError = null;
    }

    private async Task Disable2faAsync()
    {
        if (AuthState.CurrentUser is null) return;

        _processing2fa = true;
        _twoFaError = null;
        StateHasChanged();

        try
        {
            var request = new DisableTwoFactorRequestDto { Code = _disable2faOtp };
            var response = await AuthClient.DisableTwoFactorAsync(AuthState.CurrentUser.UserId, request);
            if (response.Success)
            {
                _disable2faDialogVisible = false;
                _disable2faOtp = string.Empty;
                await SyncUserProfileAsync();
                Snackbar.Add("Two-factor authentication disabled.", Severity.Success);
            }
            else
            {
                _twoFaError = response.Message ?? "Invalid code. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _twoFaError = $"Error: {ex.Message}";
        }
        finally
        {
            _processing2fa = false;
            StateHasChanged();
        }
    }
}
