@page "/auth/reset-password"
@layout AuthLayout
@inject IAuthApiClient AuthClient
@inject AuthStateService AuthState
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Reset Password - TenantCore</PageTitle>

<MudGrid Justify="Justify.Center" Style="min-height: 100vh; margin: 0;">
    <MudItem xs="12" sm="10" md="8" lg="6" xl="4">
        <MudPaper Elevation="8" Class="pa-8 rounded-lg" Style="background: white;">
            <MudStack AlignItems="AlignItems.Center" Class="mb-6">
                <MudAvatar Size="Size.Large" Color="Color.Primary" Style="width: 80px; height: 80px;">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" Style="font-size: 2.5rem;" />
                </MudAvatar>
                <MudText Typo="Typo.h4" Align="Align.Center" Class="mt-4" Style="font-weight: 600;">
                    Reset Password
                </MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                    Enter your new password below
                </MudText>
            </MudStack>

            <EditForm Model="_model" OnValidSubmit="HandleReset">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_model.NewPassword"
                              Label="New Password"
                              Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                              For="@(() => _model.NewPassword)"
                              Disabled="_loading"
                              Class="mb-4"
                              HelperText="At least 8 characters" />

                <MudTextField @bind-Value="_model.ConfirmPassword"
                              Label="Confirm Password"
                              Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              For="@(() => _model.ConfirmPassword)"
                              Disabled="_loading"
                              Class="mb-4" />

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true" Variant="Variant.Filled">
                        @_errorMessage
                    </MudAlert>
                }

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="_loading || !_hasUserId"
                           Class="mb-4"
                           Style="height: 48px;">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Surface" Class="mr-2" />
                        <span>Resetting...</span>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Save" Class="mr-2" />
                        <span>Reset Password</span>
                    }
                </MudButton>
            </EditForm>

            <MudStack AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Text" Color="Color.Secondary" Href="/auth/login">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Class="mr-1" />
                    Back to Login
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [SupplyParameterFromQuery]
    public Guid? UserId { get; set; }

    private ResetPasswordRequestDto _model = new();
    private bool _loading;
    private bool _showPassword;
    private string? _errorMessage;
    private bool _hasUserId => UserId.HasValue || AuthState.PendingPasswordResetUserId.HasValue;

    private Guid GetUserId() => UserId ?? AuthState.PendingPasswordResetUserId ?? Guid.Empty;

    private async Task HandleReset()
    {
        if (!_hasUserId)
        {
            _errorMessage = "Invalid reset request. Please try again.";
            return;
        }

        _loading = true;
        _errorMessage = null;

        try
        {
            var response = await AuthClient.ResetPasswordAsync(GetUserId(), _model);

            if (response.Success)
            {
                AuthState.ClearTempState();
                Snackbar.Add("Password reset successfully! Please log in with your new password.", Severity.Success);
                NavigationManager.NavigateTo("/auth/login");
            }
            else
            {
                _errorMessage = response.Message ?? "Password reset failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
            Console.WriteLine($"Reset error: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
