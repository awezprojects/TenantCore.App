@page "/tenants/{Id:guid}/edit"
@layout AuthorizedLayout
@inject ITenantApiClient TenantClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Tenant - TenantCore</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => NavigationManager.NavigateTo("/tenants"))" />
    <MudText Typo="Typo.h4">Edit Tenant</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_notFound)
{
    <MudPaper Class="pa-6" Elevation="2">
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Warning" Style="font-size: 4rem;" />
            <MudText Typo="Typo.h5">Tenant Not Found</MudText>
            <MudText Color="Color.Secondary">The tenant you're looking for doesn't exist.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/tenants">
                Back to Tenants
            </MudButton>
        </MudStack>
    </MudPaper>
}
else if (_loaded)
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-6" Elevation="2">
                <MudForm @ref="_form" @bind-IsValid="_formValid">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Name" 
                                          Label="Tenant Name" 
                                          Required="true" 
                                          RequiredError="Name is required."
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Business" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Subdomain" 
                                          Label="Subdomain" 
                                          Required="true" 
                                          RequiredError="Subdomain is required."
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Language"
                                          HelperText="Used for tenant-specific URLs" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_model.Description" 
                                          Label="Description" 
                                          Lines="3" 
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.ContactEmail" 
                                          Label="Contact Email" 
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Email" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.ContactPhone" 
                                          Label="Contact Phone"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Phone" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudDatePicker @bind-Date="_subscriptionExpiresAt" 
                                           Label="Subscription Expires At" 
                                           Variant="Variant.Outlined"
                                           Clearable="true" />
                        </MudItem>
                    </MudGrid>

                    <MudStack Row="true" Spacing="2" Class="mt-6" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Text" 
                                   OnClick="@(() => NavigationManager.NavigateTo("/tenants"))">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   OnClick="Submit" 
                                   Disabled="_submitting"
                                   StartIcon="@(_submitting ? null : Icons.Material.Filled.Save)">
                            @if (_submitting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Saving...</span>
                            }
                            else
                            {
                                <span>Save Changes</span>
                            }
                        </MudButton>
                    </MudStack>
                </MudForm>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Tenant Info</MudText>
                <MudStack Spacing="2">
                    <MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Tenant ID</MudText>
                        <MudText Typo="Typo.body2" Style="word-break: break-all;">@Id</MudText>
                    </MudStack>
                    <MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Created At</MudText>
                        <MudText Typo="Typo.body2">@_originalTenant?.CreatedAt.ToString("MMM dd, yyyy HH:mm")</MudText>
                    </MudStack>
                    @if (_originalTenant?.UpdatedAt.HasValue == true)
                    {
                        <MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Last Updated</MudText>
                            <MudText Typo="Typo.body2">@_originalTenant.UpdatedAt.Value.ToString("MMM dd, yyyy HH:mm")</MudText>
                        </MudStack>
                    }
                    <MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                        <MudChip T="string" Color="@(_originalTenant?.IsActive == true ? Color.Success : Color.Error)" Size="Size.Small">
                            @(_originalTenant?.IsActive == true ? "Active" : "Inactive")
                        </MudChip>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MudForm _form = null!;
    private bool _formValid;
    private bool _loading = true;
    private bool _loaded;
    private bool _notFound;
    private bool _submitting;
    private DateTime? _subscriptionExpiresAt;
    private TenantDto? _originalTenant;
    private UpdateTenantModel _model = new();

    private class UpdateTenantModel
    {
        public string Name { get; set; } = string.Empty;
        public string Subdomain { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? ContactEmail { get; set; }
        public string? ContactPhone { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tenant = await TenantClient.GetTenantByIdAsync(Id);
            if (tenant is null)
            {
                _notFound = true;
                return;
            }

            _originalTenant = tenant;
            _model.Name = tenant.Name;
            _model.Subdomain = tenant.Subdomain;
            _model.Description = tenant.Description;
            _model.ContactEmail = tenant.ContactEmail;
            _model.ContactPhone = tenant.ContactPhone;
            _subscriptionExpiresAt = tenant.SubscriptionExpiresAt;
            _loaded = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading tenant: {ex.Message}", Severity.Error);
            _notFound = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (!_formValid) return;

        _submitting = true;
        try
        {
            var dto = new UpdateTenantDto 
            { 
                Name = _model.Name, 
                Subdomain = _model.Subdomain, 
                Description = _model.Description, 
                ContactEmail = _model.ContactEmail, 
                ContactPhone = _model.ContactPhone, 
                SubscriptionExpiresAt = _subscriptionExpiresAt 
            };

            await TenantClient.UpdateTenantAsync(Id, dto);
            Snackbar.Add("Tenant updated successfully.", Severity.Success);
            NavigationManager.NavigateTo("/tenants");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating tenant: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }
}
