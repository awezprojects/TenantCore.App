@page "/tenants"
@layout AuthorizedLayout
@inject ITenantApiClient TenantClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Tenants - TenantCore</PageTitle>

@if (_accessDenied)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
        <MudPaper Elevation="4" Class="pa-8">
            <MudStack AlignItems="AlignItems.Center" Spacing="4">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Error" Style="font-size: 4rem;" />
                <MudText Typo="Typo.h5" Color="Color.Error">Access Denied</MudText>
                <MudText Typo="Typo.body1" Align="Align.Center">
                    You do not have permission to access this page.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/"
                           StartIcon="@Icons.Material.Filled.Home">
                    Go to Home
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudContainer>
}
else
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h4">Tenants</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => NavigationManager.NavigateTo("/tenants/create"))">
            Add Tenant
        </MudButton>
    </MudStack>

    <MudPaper Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_searchTerm" Label="Search tenants..." Variant="Variant.Outlined"
                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                              OnKeyUp="OnSearchKeyUp" Immediate="true" Clearable="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect T="string" @bind-Value="_statusFilter" Label="Status" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("all")">All</MudSelectItem>
                    <MudSelectItem Value="@("active")">Active</MudSelectItem>
                    <MudSelectItem Value="@("inactive")">Inactive</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-end">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                           OnClick="LoadTenantsAsync" StartIcon="@Icons.Material.Filled.Refresh">
                    Refresh
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_result is not null)
    {
        <MudTable Items="@FilteredTenants" Hover="true" Striped="true" Bordered="true"
                  Dense="false" Breakpoint="Breakpoint.Sm" Class="mb-4" Elevation="2">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TenantDto, object>(x => x.Name)">Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TenantDto, object>(x => x.Subdomain)">Subdomain</MudTableSortLabel></MudTh>
                <MudTh>Contact Email</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Subscription</MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TenantDto, object>(x => x.CreatedAt)">Created</MudTableSortLabel></MudTh>
                <MudTh Style="width: 120px;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate Context="tenant">
                <MudTd DataLabel="Name">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudAvatar Size="Size.Small" Color="Color.Primary">
                            @tenant.Name[0]
                        </MudAvatar>
                        <MudText>@tenant.Name</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Subdomain">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@tenant.Subdomain</MudChip>
                </MudTd>
                <MudTd DataLabel="Contact Email">@(tenant.ContactEmail ?? "-")</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@(tenant.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                        @(tenant.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Subscription">
                    @if (tenant.SubscriptionExpiresAt.HasValue)
                    {
                        var isExpiringSoon = tenant.SubscriptionExpiresAt.Value <= DateTime.UtcNow.AddDays(30);
                        var isExpired = tenant.SubscriptionExpiresAt.Value <= DateTime.UtcNow;
                        <MudChip T="string" Color="@(isExpired ? Color.Error : isExpiringSoon ? Color.Warning : Color.Default)" 
                                 Size="Size.Small" Variant="Variant.Text">
                            @tenant.SubscriptionExpiresAt.Value.ToString("MMM dd, yyyy")
                        </MudChip>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">-</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Created">@tenant.CreatedAt.ToString("MMM dd, yyyy")</MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="View Details">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small"
                                           OnClick="@(() => ViewTenant(tenant))" />
                        </MudTooltip>
                        <MudTooltip Text="Edit">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                           OnClick="@(() => NavigationManager.NavigateTo($"/tenants/{tenant.Id}/edit"))" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => ConfirmDelete(tenant))" />
                        </MudTooltip>
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 25, 50 }" />
            </PagerContent>
            <NoRecordsContent>
                <MudText Color="Color.Secondary">No tenants found.</MudText>
            </NoRecordsContent>
        </MudTable>

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Showing @_result.Items.Count of @_result.TotalCount tenants
            </MudText>
            <MudPagination Count="_result.TotalPages" @bind-Selected="_currentPage"
                           ShowFirstButton="true" ShowLastButton="true" />
        </MudStack>
    }

    <!-- View Tenant Dialog -->
    <MudDialog @bind-Visible="_viewDialogVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">Tenant Details</MudText>
        </TitleContent>
        <DialogContent>
            @if (_selectedTenant != null)
            {
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudAvatar Size="Size.Large" Color="Color.Primary">
                            @_selectedTenant.Name[0]
                        </MudAvatar>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6">@_selectedTenant.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_selectedTenant.Subdomain</MudText>
                        </MudStack>
                    </MudStack>
                    <MudDivider />
                    <MudGrid>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Description</MudText>
                            <MudText>@(_selectedTenant.Description ?? "N/A")</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                            <MudChip T="string" Color="@(_selectedTenant.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                                @(_selectedTenant.IsActive ? "Active" : "Inactive")
                            </MudChip>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Contact Email</MudText>
                            <MudText>@(_selectedTenant.ContactEmail ?? "N/A")</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Contact Phone</MudText>
                            <MudText>@(_selectedTenant.ContactPhone ?? "N/A")</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Created At</MudText>
                            <MudText>@_selectedTenant.CreatedAt.ToString("MMM dd, yyyy HH:mm")</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Subscription Expires</MudText>
                            <MudText>@(_selectedTenant.SubscriptionExpiresAt?.ToString("MMM dd, yyyy") ?? "N/A")</MudText>
                        </MudItem>
                    </MudGrid>
                </MudStack>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _viewDialogVisible = false)">Close</MudButton>
            <MudButton Color="Color.Primary" OnClick="@(() => NavigationManager.NavigateTo($"/tenants/{_selectedTenant?.Id}/edit"))">
                Edit
            </MudButton>
        </DialogActions>
    </MudDialog>

    <!-- Delete Confirmation Dialog -->
    <MudDialog @bind-Visible="_deleteDialogVisible">
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
                <MudText Typo="Typo.h6">Confirm Delete</MudText>
            </MudStack>
        </TitleContent>
        <DialogContent>
            <MudText>Are you sure you want to delete tenant <b>@_tenantToDelete?.Name</b>?</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                This action cannot be undone.
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _deleteDialogVisible = false)">Cancel</MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="DeleteTenant">Delete</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private PagedResult<TenantDto>? _result;
    private bool _loading = true;
    private bool _accessDenied;
    private string? _searchTerm;
    private string _statusFilter = "all";
    private int _currentPage = 1;
    private bool _deleteDialogVisible;
    private bool _viewDialogVisible;
    private TenantDto? _tenantToDelete;
    private TenantDto? _selectedTenant;

    private IEnumerable<TenantDto> FilteredTenants => _result?.Items
        .Where(t => _statusFilter == "all" || 
                    (_statusFilter == "active" && t.IsActive) || 
                    (_statusFilter == "inactive" && !t.IsActive)) ?? [];

    protected override async Task OnInitializedAsync()
    {
        await LoadTenantsAsync();
    }

    private async Task LoadTenantsAsync()
    {
        _loading = true;
        _accessDenied = false;

        try
        {
            _result = await TenantClient.GetTenantsAsync(_currentPage, 50, _searchTerm);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            NavigationManager.NavigateTo("/auth/login", forceLoad: true);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Forbidden)
        {
            _accessDenied = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading tenants: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _currentPage = 1;
            await LoadTenantsAsync();
        }
    }

    private void ViewTenant(TenantDto tenant)
    {
        _selectedTenant = tenant;
        _viewDialogVisible = true;
    }

    private void ConfirmDelete(TenantDto tenant)
    {
        _tenantToDelete = tenant;
        _deleteDialogVisible = true;
    }

    private async Task DeleteTenant()
    {
        if (_tenantToDelete is null) return;
        try
        {
            await TenantClient.DeleteTenantAsync(_tenantToDelete.Id);
            Snackbar.Add($"Tenant '{_tenantToDelete.Name}' deleted successfully.", Severity.Success);
            _deleteDialogVisible = false;
            _tenantToDelete = null;
            await LoadTenantsAsync();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Forbidden)
        {
            Snackbar.Add("You don't have permission to delete tenants.", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting tenant: {ex.Message}", Severity.Error);
        }
    }
}
