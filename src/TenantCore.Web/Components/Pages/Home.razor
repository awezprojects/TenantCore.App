@page "/"
<PageTitle>Home</PageTitle>
<MudText Typo="Typo.h3" GutterBottom="true">Welcome to TenantCore</MudText>
<MudText Typo="Typo.body1" Class="mb-4">A production-ready multi-tenant management platform built with Clean Architecture.</MudText>
<MudGrid>
    <MudItem xs="12" md="4">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">Tenant Management</MudText></CardHeaderContent>
                <CardHeaderAvatar><MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" /></CardHeaderAvatar>
            </MudCardHeader>
            <MudCardContent><MudText>Manage your tenants, subscriptions, and configurations.</MudText></MudCardContent>
            <MudCardActions><MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tenants">Go to Tenants</MudButton></MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>
