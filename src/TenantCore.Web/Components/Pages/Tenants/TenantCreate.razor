@page "/tenants/create"
@using TenantCore.Web.Clients
@using TenantCore.Shared.Dtos
@inject ITenantApiClient TenantClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Create Tenant</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Create Tenant</MudText>
<MudPaper Class="pa-6" MaxWidth="600px">
    <MudForm @ref="_form" @bind-IsValid="_formValid">
        <MudTextField @bind-Value="_name" Label="Name" Required="true" RequiredError="Name is required." Class="mb-3" />
        <MudTextField @bind-Value="_subdomain" Label="Subdomain" Required="true" RequiredError="Subdomain is required." Class="mb-3" />
        <MudTextField @bind-Value="_description" Label="Description" Lines="3" Class="mb-3" />
        <MudTextField @bind-Value="_contactEmail" Label="Contact Email" InputType="InputType.Email" Class="mb-3" />
        <MudTextField @bind-Value="_contactPhone" Label="Contact Phone" Class="mb-3" />
        <MudDatePicker @bind-Date="_subscriptionExpiresAt" Label="Subscription Expires At" Class="mb-4" Clearable="true" />
        <MudStack Row="true" Spacing="2" Class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="_submitting">Create</MudButton>
            <MudButton Variant="Variant.Text" OnClick="@(() => NavigationManager.NavigateTo("/tenants"))">Cancel</MudButton>
        </MudStack>
    </MudForm>
</MudPaper>

@code {
    private MudForm _form = null!;
    private bool _formValid;
    private bool _submitting;
    private DateTime? _subscriptionExpiresAt;
    private string _name = string.Empty;
    private string _subdomain = string.Empty;
    private string? _description;
    private string? _contactEmail;
    private string? _contactPhone;

    private async Task Submit()
    {
        await _form.Validate();
        if (!_formValid) return;
        _submitting = true;
        try
        {
            var dto = new CreateTenantDto { Name = _name, Subdomain = _subdomain, Description = _description, ContactEmail = _contactEmail, ContactPhone = _contactPhone, SubscriptionExpiresAt = _subscriptionExpiresAt };
            await TenantClient.CreateTenantAsync(dto);
            Snackbar.Add("Tenant created successfully.", Severity.Success);
            NavigationManager.NavigateTo("/tenants");
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _submitting = false; }
    }
}
