@page "/tenants/{Id:guid}/edit"
@using TenantCore.Web.Clients
@using TenantCore.Shared.Dtos
@inject ITenantApiClient TenantClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Edit Tenant</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Edit Tenant</MudText>
@if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" /> }
else if (_loaded)
{
    <MudPaper Class="pa-6" MaxWidth="600px">
        <MudForm @ref="_form" @bind-IsValid="_formValid">
            <MudTextField @bind-Value="_name" Label="Name" Required="true" RequiredError="Name is required." Class="mb-3" />
            <MudTextField @bind-Value="_subdomain" Label="Subdomain" Required="true" RequiredError="Subdomain is required." Class="mb-3" />
            <MudTextField @bind-Value="_description" Label="Description" Lines="3" Class="mb-3" />
            <MudTextField @bind-Value="_contactEmail" Label="Contact Email" InputType="InputType.Email" Class="mb-3" />
            <MudTextField @bind-Value="_contactPhone" Label="Contact Phone" Class="mb-3" />
            <MudDatePicker @bind-Date="_subscriptionExpiresAt" Label="Subscription Expires At" Class="mb-4" Clearable="true" />
            <MudStack Row="true" Spacing="2" Class="mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="_submitting">Save</MudButton>
                <MudButton Variant="Variant.Text" OnClick="@(() => NavigationManager.NavigateTo("/tenants"))">Cancel</MudButton>
            </MudStack>
        </MudForm>
    </MudPaper>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private MudForm _form = null!;
    private bool _formValid, _loading = true, _loaded, _submitting;
    private DateTime? _subscriptionExpiresAt;
    private string _name = string.Empty, _subdomain = string.Empty;
    private string? _description, _contactEmail, _contactPhone;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var t = await TenantClient.GetTenantByIdAsync(Id);
            if (t is null) { Snackbar.Add("Tenant not found.", Severity.Error); NavigationManager.NavigateTo("/tenants"); return; }
            _name = t.Name; _subdomain = t.Subdomain; _description = t.Description; _contactEmail = t.ContactEmail; _contactPhone = t.ContactPhone; _subscriptionExpiresAt = t.SubscriptionExpiresAt; _loaded = true;
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (!_formValid) return;
        _submitting = true;
        try
        {
            var dto = new UpdateTenantDto { Name = _name, Subdomain = _subdomain, Description = _description, ContactEmail = _contactEmail, ContactPhone = _contactPhone, SubscriptionExpiresAt = _subscriptionExpiresAt };
            await TenantClient.UpdateTenantAsync(Id, dto);
            Snackbar.Add("Tenant updated successfully.", Severity.Success);
            NavigationManager.NavigateTo("/tenants");
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _submitting = false; }
    }
}
