@page "/tenants"
@using TenantCore.Web.Clients
@using TenantCore.Shared.Dtos
@using TenantCore.Shared.Common
@inject ITenantApiClient TenantClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Tenants</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Tenants</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudTextField @bind-Value="_searchTerm" Label="Search" Variant="Variant.Outlined"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                          OnKeyUp="OnSearchKeyUp" Immediate="true" />
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => NavigationManager.NavigateTo("/tenants/create"))">
                Add Tenant
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_result is not null)
{
    <MudTable Items="_result.Items" Hover="true" Striped="true" Bordered="true"
              Dense="false" Breakpoint="Breakpoint.Sm" Class="mb-4">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Subdomain</MudTh>
            <MudTh>Contact Email</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Created</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Subdomain">@context.Subdomain</MudTd>
            <MudTd DataLabel="Contact Email">@context.ContactEmail</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.IsActive ? "Active" : "Inactive")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Created">@context.CreatedAt.ToString("yyyy-MM-dd")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                               OnClick="@(() => NavigationManager.NavigateTo($"/tenants/{context.Id}/edit"))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => ConfirmDelete(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudPagination Count="_result.TotalPages" @bind-Selected="_currentPage"
                   ShowFirstButton="true" ShowLastButton="true" />
}

<MudDialog @bind-Visible="_deleteDialogVisible">
    <TitleContent>Confirm Delete</TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to delete tenant <b>@_tenantToDelete?.Name</b>?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _deleteDialogVisible = false)">Cancel</MudButton>
        <MudButton Color="Color.Error" OnClick="DeleteTenant">Delete</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private PagedResult<TenantDto>? _result;
    private bool _loading = true;
    private string? _searchTerm;
    private int _currentPage = 1;
    private bool _deleteDialogVisible;
    private TenantDto? _tenantToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadTenantsAsync();
    }

    private async Task LoadTenantsAsync()
    {
        _loading = true;
        try
        {
            _result = await TenantClient.GetTenantsAsync(_currentPage, 10, _searchTerm);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading tenants: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _currentPage = 1;
            await LoadTenantsAsync();
        }
    }

    private void ConfirmDelete(TenantDto tenant)
    {
        _tenantToDelete = tenant;
        _deleteDialogVisible = true;
    }

    private async Task DeleteTenant()
    {
        if (_tenantToDelete is null) return;
        try
        {
            await TenantClient.DeleteTenantAsync(_tenantToDelete.Id);
            Snackbar.Add($"Tenant '{_tenantToDelete.Name}' deleted.", Severity.Success);
            _deleteDialogVisible = false;
            _tenantToDelete = null;
            await LoadTenantsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting tenant: {ex.Message}", Severity.Error);
        }
    }
}
